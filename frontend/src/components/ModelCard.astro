---
// ModelCard component
export interface Props {
  id: string;
  name: string;
  description: string;
  type: string;
  tags: string[];
}

const { id, name, description, type, tags } = Astro.props;

const typeColors: Record<string, string> = {
  classification: 'badge-blue',
  regression:     'badge-violet',
  generation:     'badge-green',
};
---

<a href={`/playground?model=${id}`} class="model-card card" id={`model-card-${id}`}>
  <div class="model-card-header">
    <div class="model-icon">
      {type === 'classification' ? '🔮' : type === 'regression' ? '📈' : '✨'}
    </div>
    <span class={`badge ${typeColors[type] ?? 'badge-blue'}`}>
      {type}
    </span>
  </div>

  <h3 class="model-name">{name}</h3>
  <p class="model-description">{description}</p>

  <div class="model-tags">
    {tags.map(t => (
      <span class="tag">{t}</span>
    ))}
  </div>

  <div class="model-cta">
    <span>Try it now</span>
    <span class="arrow">→</span>
  </div>
</a>

<style>
  .model-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .model-card:hover .arrow {
    transform: translateX(5px);
  }

  .model-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .model-icon {
    font-size: 2rem;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.05);
    border-radius: 12px;
  }

  .model-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--clr-text);
  }

  .model-description {
    font-size: 0.85rem;
    color: var(--clr-muted);
    line-height: 1.55;
    flex: 1;
  }

  .model-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.72rem;
    padding: 0.15rem 0.55rem;
    background: rgba(255,255,255,0.05);
    border-radius: 99px;
    color: var(--clr-muted);
    border: 1px solid var(--clr-border);
    font-family: var(--font-mono);
  }

  .model-cta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--clr-primary);
    margin-top: 0.25rem;
  }

  .arrow {
    display: inline-block;
    transition: transform 0.2s;
  }
</style>
