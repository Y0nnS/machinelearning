---
import { ArrowUpRight, Flower2, Grid3X3, Workflow } from 'lucide-astro';

export interface Props {
  id: string;
  name: string;
  description: string;
  type: string;
  tags: string[];
}

const { id, name, description, type, tags } = Astro.props;
const Icon = id.includes('digits') ? Grid3X3 : id.includes('iris') ? Flower2 : Workflow;
---

<a href={`/playground?model=${id}`} class="model-card panel panel-pad">
  <div class="model-card-top">
    <span class="icon-tile"><Icon size={18} /></span>
    <span class="chip blue">{type}</span>
  </div>

  <div class="model-card-body">
    <h3>{name}</h3>
    <p>{description}</p>
  </div>

  <div class="model-card-foot">
    <div class="model-tags">
      {tags.slice(0, 3).map((tag) => <span class="chip">{tag}</span>)}
    </div>
    <ArrowUpRight size={17} />
  </div>
</a>

<style>
  .model-card {
    display: grid;
    min-height: 220px;
    color: inherit;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .model-card:hover {
    border-color: var(--border-strong);
    background: var(--surface-2);
  }

  .model-card-top,
  .model-card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .model-card-body {
    align-self: center;
  }

  .model-card h3 {
    margin: 0;
    max-width: 14rem;
    color: var(--text);
    font-size: 1.15rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .model-card p {
    margin: 10px 0 0;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.55;
  }

  .model-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .model-card-foot svg {
    flex: 0 0 auto;
    color: var(--muted-2);
  }
</style>
