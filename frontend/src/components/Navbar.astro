---
const links = [
  { href: '/', label: 'Home' },
  { href: '/models', label: 'Models' },
  { href: '/playground', label: 'Playground' },
  { href: '/docs', label: 'API', external: true, href2: 'http://localhost:8000/docs' },
];

const pathname = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-bg-main/80 backdrop-blur-md border-b border-border">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 text-text-main font-semibold hover:text-white transition-colors">
      <svg class="w-5 h-5 text-accent" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
      <span>Nexus AI</span>
    </a>

    <ul class="flex items-center gap-1">
      {links.map(link => (
        <li>
          <a
            href={link.external ? link.href2 : link.href}
            target={link.external ? '_blank' : '_self'}
            class={`px-4 py-2 rounded-md text-sm font-medium transition-all ${
              !link.external && pathname === link.href 
                ? 'text-accent bg-accent/10' 
                : 'text-text-muted hover:text-text-main hover:bg-surface'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2 text-xs text-text-muted">
      <span id="status-dot" class="w-2 h-2 rounded-full bg-yellow-500 animate-pulse"></span>
      <span id="status-label">Checking</span>
    </div>
  </div>
</nav>

<script>
  async function checkApiStatus() {
    const dot = document.getElementById('status-dot');
    const label = document.getElementById('status-label');
    if (!dot || !label) return;
    
    try {
      const res = await fetch('http://localhost:8000/health', { signal: AbortSignal.timeout(3000) });
      if (res.ok) {
        dot.className = 'w-2 h-2 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.4)]';
        label.textContent = 'Online';
      } else {
        throw new Error('non-ok');
      }
    } catch {
      dot.className = 'w-2 h-2 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.4)]';
      label.textContent = 'Offline';
    }
  }

  checkApiStatus();
  setInterval(checkApiStatus, 10000);
</script>
