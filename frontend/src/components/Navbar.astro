---
import { Activity, Boxes, BrainCircuit, ExternalLink, Home, SquareTerminal } from 'lucide-astro';

const links = [
  { href: '/', label: 'Lab', icon: Home },
  { href: '/playground', label: 'Playground', icon: SquareTerminal },
  { href: '/models', label: 'Models', icon: Boxes },
];

const pathname = Astro.url.pathname;
---

<nav class="topbar">
  <div class="app-container topbar-inner">
    <a href="/" class="brand" aria-label="AI Lab home">
      <span class="brand-mark"><BrainCircuit size={18} /></span>
      <span>AI Lab</span>
    </a>

    <div class="nav-links" aria-label="Primary navigation">
      {links.map((link) => {
        const Icon = link.icon;
        const active = pathname === link.href;
        return (
          <a href={link.href} class={`nav-link ${active ? 'active' : ''}`} aria-current={active ? 'page' : undefined}>
            <Icon size={16} />
            <span>{link.label}</span>
          </a>
        );
      })}
      <a href="http://localhost:8000/docs" target="_blank" rel="noreferrer" class="nav-link" id="api-docs-link">
        <ExternalLink size={16} />
        <span>API</span>
      </a>
    </div>

    <div class="status-pill" id="api-status" title="Backend status">
      <span class="dot" id="api-dot"></span>
      <Activity size={14} />
      <span id="api-label">checking</span>
    </div>
  </div>
</nav>

<script>
  const statusDot = document.getElementById('api-dot');
  const statusLabel = document.getElementById('api-label');
  const apiDocsLink = document.getElementById('api-docs-link');

  function getApiBase() {
    const params = new URLSearchParams(window.location.search);
    const fromParam = params.get('api');
    if (fromParam) {
      localStorage.setItem('ai_lab_api', fromParam);
      return fromParam.replace(/\/$/, '');
    }
    return (localStorage.getItem('ai_lab_api') || 'http://localhost:8000').replace(/\/$/, '');
  }

  async function refreshApiStatus() {
    if (!statusDot || !statusLabel) return;

    try {
      const response = await fetch(`${getApiBase()}/health`, {
        signal: AbortSignal.timeout(2500),
      });

      if (!response.ok) throw new Error('offline');
      statusDot.className = 'dot ready';
      statusLabel.textContent = 'online';
    } catch {
      statusDot.className = 'dot error';
      statusLabel.textContent = 'offline';
    }
  }

  if (apiDocsLink instanceof HTMLAnchorElement) {
    apiDocsLink.href = `${getApiBase()}/docs`;
  }

  refreshApiStatus();
  window.setInterval(refreshApiStatus, 10000);
</script>
