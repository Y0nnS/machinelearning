---
import { Activity, Boxes } from 'lucide-astro';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ModelCard from '../components/ModelCard.astro';

const models = [
  {
    id: 'iris_classifier',
    name: 'Iris Classifier',
    description: 'Four numeric features, three flower classes, scikit-learn pipeline.',
    type: 'classification',
    tags: ['python', 'sklearn', 'random forest'],
  },
  {
    id: 'digits_classifier',
    name: 'Digit Recognizer',
    description: '8x8 pixel input, ten classes, SVM probability output.',
    type: 'classification',
    tags: ['python', 'sklearn', 'svm'],
  },
];
---

<Layout title="Models" description="Built-in AI lab models">
  <Navbar />

  <main class="page">
    <div class="app-container">
      <div class="section-head">
        <div>
          <div class="eyebrow">model shelf</div>
          <h1 class="mini-title models-title">Built-ins</h1>
        </div>
        <span class="status-pill" id="models-status">
          <span class="dot"></span>
          <Activity size={14} />
          checking
        </span>
      </div>

      <div class="models-grid">
        {models.map((model) => <ModelCard {...model} />)}

        <a class="panel panel-pad add-card" href="/playground#external">
          <span class="icon-tile"><Boxes size={18} /></span>
          <div>
            <h2>External API</h2>
            <p>OpenAI-compatible provider via backend env.</p>
          </div>
        </a>
      </div>
    </div>
  </main>
</Layout>

<script>
  const status = document.getElementById('models-status');

  function getApiBase() {
    const params = new URLSearchParams(window.location.search);
    const fromParam = params.get('api');
    if (fromParam) {
      localStorage.setItem('ai_lab_api', fromParam);
      return fromParam.replace(/\/$/, '');
    }
    return (localStorage.getItem('ai_lab_api') || 'http://localhost:8000').replace(/\/$/, '');
  }

  async function refreshModelStatus() {
    if (!status) return;

    try {
      const response = await fetch(`${getApiBase()}/api/models/`);
      if (!response.ok) throw new Error('offline');
      const data = await response.json();
      status.innerHTML = `<span class="dot ready"></span><span>${data.models.length} ready</span>`;
    } catch {
      status.innerHTML = '<span class="dot error"></span><span>offline</span>';
    }
  }

  refreshModelStatus();
</script>

<style>
  .models-title {
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .models-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .add-card {
    display: grid;
    min-height: 220px;
    align-content: space-between;
    color: inherit;
  }

  .add-card:hover {
    border-color: var(--border-strong);
    background: var(--surface-2);
  }

  .add-card h2 {
    margin: 0;
    color: var(--text);
    font-size: 1.15rem;
    font-weight: 800;
  }

  .add-card p {
    margin: 10px 0 0;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .models-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
