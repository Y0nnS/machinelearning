---
import { Boxes, BrainCircuit, Cpu, Database, Play, PlugZap, SquareTerminal } from 'lucide-astro';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="AI Lab" description="Local AI playground with Python and Go engines">
  <Navbar />

  <main class="page">
    <div class="app-container home-grid">
      <section class="hero-copy">
        <div class="eyebrow">local ai lab</div>
        <h1 class="title">Build. Test. Learn.</h1>
        <p class="subtitle">Python models, Go engine, optional external API. One dark workspace for fast AI experiments.</p>

        <div class="hero-actions">
          <a class="button primary" href="/playground">
            <SquareTerminal size={17} />
            Playground
          </a>
          <a class="button" href="/models">
            <Boxes size={17} />
            Models
          </a>
        </div>
      </section>

      <section class="panel panel-pad quick-lab" aria-label="Quick text AI">
        <div class="quick-head">
          <span class="icon-tile"><BrainCircuit size={18} /></span>
          <div>
            <div class="eyebrow">go engine</div>
            <h2 class="mini-title">Text probe</h2>
          </div>
        </div>

        <form id="quick-form" class="quick-form">
          <textarea
            id="quick-input"
            class="textarea"
            rows="5"
            placeholder="Tulis prompt pendek..."
          >aku mau belajar backend ai pakai go dan python</textarea>
          <button class="button primary" id="quick-run" type="submit">
            <Play size={16} />
            Run
          </button>
        </form>

        <pre class="result-box" id="quick-output">idle</pre>
      </section>
    </div>

    <div class="app-container runtime-grid">
      <article class="runtime-item panel panel-pad" data-engine-card="python_sklearn">
        <Database size={18} />
        <div>
          <strong>Python</strong>
          <span id="engine-python_sklearn">checking</span>
        </div>
      </article>

      <article class="runtime-item panel panel-pad" data-engine-card="go_text_ai">
        <Cpu size={18} />
        <div>
          <strong>Go</strong>
          <span id="engine-go_text_ai">checking</span>
        </div>
      </article>

      <article class="runtime-item panel panel-pad" data-engine-card="external_ai">
        <PlugZap size={18} />
        <div>
          <strong>API</strong>
          <span id="engine-external_ai">checking</span>
        </div>
      </article>
    </div>
  </main>
</Layout>

<script>
  function getApiBase() {
    const params = new URLSearchParams(window.location.search);
    const fromParam = params.get('api');
    if (fromParam) {
      localStorage.setItem('ai_lab_api', fromParam);
      return fromParam.replace(/\/$/, '');
    }
    return (localStorage.getItem('ai_lab_api') || 'http://localhost:8000').replace(/\/$/, '');
  }

  const API = getApiBase();
  const quickForm = document.getElementById('quick-form');
  const quickInput = document.getElementById('quick-input');
  const quickOutput = document.getElementById('quick-output');
  const quickRun = document.getElementById('quick-run');

  function printQuick(value) {
    if (quickOutput) quickOutput.textContent = value;
  }

  async function refreshEngines() {
    try {
      const response = await fetch(`${API}/api/lab/engines`);
      if (!response.ok) throw new Error('Backend offline');
      const data = await response.json();

      data.engines.forEach((engine) => {
        const target = document.getElementById(`engine-${engine.id}`);
        const card = document.querySelector(`[data-engine-card="${engine.id}"]`);
        if (target) target.textContent = engine.status;
        if (card) card.setAttribute('data-status', engine.status);
      });
    } catch {
      ['python_sklearn', 'go_text_ai', 'external_ai'].forEach((id) => {
        const target = document.getElementById(`engine-${id}`);
        const card = document.querySelector(`[data-engine-card="${id}"]`);
        if (target) target.textContent = 'offline';
        if (card) card.setAttribute('data-status', 'offline');
      });
    }
  }

  quickForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const text = quickInput?.value?.trim();
    if (!text) return;

    quickRun?.setAttribute('disabled', 'true');
    printQuick('running...');

    try {
      const response = await fetch(`${API}/api/lab/text/analyze`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text }),
      });
      const data = await response.json();
      if (!response.ok) throw new Error(data.detail || 'Request failed');
      printQuick(JSON.stringify(data, null, 2));
    } catch (error) {
      printQuick(error instanceof Error ? error.message : 'Request failed');
    } finally {
      quickRun?.removeAttribute('disabled');
    }
  });

  refreshEngines();
</script>

<style>
  .home-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(380px, 1fr);
    gap: 20px;
    align-items: stretch;
  }

  .hero-copy {
    display: flex;
    min-height: 520px;
    flex-direction: column;
    justify-content: center;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 22px;
  }

  .quick-lab {
    display: grid;
    gap: 16px;
  }

  .quick-head {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .quick-form {
    display: grid;
    gap: 10px;
  }

  .quick-form .button {
    justify-self: end;
  }

  .runtime-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 20px;
  }

  .runtime-item {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--muted);
  }

  .runtime-item svg {
    color: var(--muted-2);
  }

  .runtime-item strong,
  .runtime-item span {
    display: block;
  }

  .runtime-item strong {
    color: var(--text);
    font-size: 0.9rem;
  }

  .runtime-item span {
    margin-top: 2px;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .runtime-item[data-status="ready"] svg,
  .runtime-item[data-status="ready"] span {
    color: var(--green);
  }

  .runtime-item[data-status="unconfigured"] svg,
  .runtime-item[data-status="unconfigured"] span,
  .runtime-item[data-status="unavailable"] svg,
  .runtime-item[data-status="unavailable"] span,
  .runtime-item[data-status="fallback"] svg,
  .runtime-item[data-status="fallback"] span {
    color: var(--amber);
  }

  .runtime-item[data-status="offline"] svg,
  .runtime-item[data-status="offline"] span,
  .runtime-item[data-status="missing"] svg,
  .runtime-item[data-status="missing"] span {
    color: var(--red);
  }

  @media (max-width: 900px) {
    .home-grid,
    .runtime-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      min-height: auto;
      padding: 28px 0 8px;
    }
  }
</style>
