---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Nexus AI - Multi-Language ML Backend">
  <Navbar />

  <main class="flex-1 flex flex-col items-center justify-center p-6 text-center mt-12 mb-20">
    <div class="max-w-4xl w-full flex flex-col items-center gap-8 fade-in-up">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-surface border border-border text-xs font-medium text-text-muted">
        <svg class="w-3.5 h-3.5 text-accent" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        Ready to Train
      </div>

      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-white leading-tight">
        Teach your AI, <br />
        <span class="text-accent">your way.</span>
      </h1>

      <p class="text-lg text-text-muted max-w-xl mx-auto leading-relaxed">
        A polyglot machine learning backend supporting Python, C++, Rust, and Go. High performance inference meets a beautiful minimal frontend.
      </p>

      <div class="flex items-center gap-4 mt-2">
        <a href="/playground" class="px-6 py-3 rounded-lg bg-accent text-white text-sm font-medium hover:bg-blue-600 transition-all inline-flex items-center gap-2 shadow-[0_0_24px_rgba(59,130,246,0.3)] hover:shadow-[0_0_32px_rgba(59,130,246,0.5)]">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Open Playground
        </a>
        <a href="/models" class="px-6 py-3 rounded-lg bg-surface border border-border text-text-main text-sm font-medium hover:bg-border transition-colors">
          Browse Models
        </a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full mt-20 text-left">
        <div class="p-6 rounded-2xl bg-surface/50 border border-border flex flex-col gap-4 hover:border-border/80 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-border/50 flex items-center justify-center text-accent">
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" x2="15" y1="20" y2="20"/><line x1="12" x2="12" y1="4" y2="20"/></svg>
          </div>
          <div>
            <h3 class="font-medium text-white mb-1.5">Polyglot Core</h3>
            <p class="text-sm text-text-muted leading-relaxed">Mix languages for maximum performance. Heavy lifting in Rust/C++, logic in Go/Python.</p>
          </div>
        </div>
        <div class="p-6 rounded-2xl bg-surface/50 border border-border flex flex-col gap-4 hover:border-border/80 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-border/50 flex items-center justify-center text-accent">
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/></svg>
          </div>
          <div>
            <h3 class="font-medium text-white mb-1.5">Manual Training</h3>
            <p class="text-sm text-text-muted leading-relaxed">Interactive interfaces to manually curate, train, and test your models instantly.</p>
          </div>
        </div>
        <div class="p-6 rounded-2xl bg-surface/50 border border-border flex flex-col gap-4 hover:border-border/80 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-border/50 flex items-center justify-center text-accent">
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <div>
            <h3 class="font-medium text-white mb-1.5">Real-time Inference</h3>
            <p class="text-sm text-text-muted leading-relaxed">Low latency REST & gRPC APIs designed for rapid prototyping and deployment.</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
