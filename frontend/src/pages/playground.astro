---
import {
  Activity,
  Bot,
  Cpu,
  Database,
  Eraser,
  Flower2,
  Grid3X3,
  MessageSquare,
  Play,
  PlugZap,
  Send,
  SlidersHorizontal,
} from 'lucide-astro';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Playground" description="Test local and external AI engines">
  <Navbar />

  <main class="page lab-page">
    <div class="app-container lab-shell">
      <aside class="panel tool-rail" aria-label="AI tools">
        <button class="tool-tab active" type="button" data-tool="text">
          <MessageSquare size={17} />
          <span>Text</span>
        </button>
        <button class="tool-tab" type="button" data-tool="iris">
          <Flower2 size={17} />
          <span>Iris</span>
        </button>
        <button class="tool-tab" type="button" data-tool="digits">
          <Grid3X3 size={17} />
          <span>Digit</span>
        </button>
        <button class="tool-tab" type="button" data-tool="external">
          <PlugZap size={17} />
          <span>API</span>
        </button>
      </aside>

      <section class="panel work-panel">
        <div class="work-top">
          <div>
            <div class="eyebrow" id="tool-runtime">go runtime</div>
            <h1 class="mini-title" id="tool-title">Text AI</h1>
          </div>
          <div class="runtime-chips" id="runtime-chips">
            <span class="chip amber">checking</span>
          </div>
        </div>

        <div class="tool-screen active" data-screen="text">
          <div class="field">
            <label for="text-input">Prompt</label>
            <textarea id="text-input" class="textarea" rows="8" placeholder="Tulis prompt...">aku lagi belajar bikin backend ai pakai go, python, dan api external</textarea>
          </div>
          <div class="action-row">
            <button class="button primary" type="button" id="text-run">
              <Play size={16} />
              Analyze
            </button>
          </div>
        </div>

        <div class="tool-screen" data-screen="iris">
          <div class="slider-list">
            <div class="field-row">
              <label for="iris-sepal-length">Sepal length <span id="iris-sepal-length-value">5.1</span></label>
              <input class="range" id="iris-sepal-length" data-iris="sepal-length" type="range" min="0" max="10" step="0.1" value="5.1" />
            </div>
            <div class="field-row">
              <label for="iris-sepal-width">Sepal width <span id="iris-sepal-width-value">3.5</span></label>
              <input class="range" id="iris-sepal-width" data-iris="sepal-width" type="range" min="0" max="10" step="0.1" value="3.5" />
            </div>
            <div class="field-row">
              <label for="iris-petal-length">Petal length <span id="iris-petal-length-value">1.4</span></label>
              <input class="range" id="iris-petal-length" data-iris="petal-length" type="range" min="0" max="10" step="0.1" value="1.4" />
            </div>
            <div class="field-row">
              <label for="iris-petal-width">Petal width <span id="iris-petal-width-value">0.2</span></label>
              <input class="range" id="iris-petal-width" data-iris="petal-width" type="range" min="0" max="10" step="0.1" value="0.2" />
            </div>
          </div>
          <div class="action-row">
            <button class="button primary" type="button" id="iris-run">
              <SlidersHorizontal size={16} />
              Predict
            </button>
          </div>
        </div>

        <div class="tool-screen" data-screen="digits">
          <div class="digit-wrap">
            <div class="digit-grid" id="digit-grid" aria-label="8 by 8 digit grid"></div>
          </div>
          <div class="action-row split">
            <button class="button" type="button" id="digit-clear">
              <Eraser size={16} />
              Clear
            </button>
            <button class="button primary" type="button" id="digit-run">
              <Grid3X3 size={16} />
              Predict
            </button>
          </div>
        </div>

        <div class="tool-screen" data-screen="external" id="external">
          <div class="field">
            <label for="external-model">Model</label>
            <input id="external-model" class="input" placeholder="backend default" />
          </div>
          <div class="field">
            <label for="external-message">Message</label>
            <textarea id="external-message" class="textarea" rows="8" placeholder="Kirim ke provider external...">jelaskan neural network dengan contoh kecil</textarea>
          </div>
          <div class="action-row">
            <button class="button primary" type="button" id="external-run">
              <Send size={16} />
              Send
            </button>
          </div>
        </div>
      </section>

      <aside class="panel output-panel" aria-live="polite">
        <div class="output-head">
          <span class="icon-tile"><Activity size={18} /></span>
          <div>
            <div class="eyebrow">output</div>
            <h2 class="mini-title" id="result-label">Idle</h2>
          </div>
        </div>

        <div class="result-meta">
          <span class="chip" id="result-meta">waiting</span>
          <span class="chip blue" id="result-engine">none</span>
        </div>

        <div class="prob-list" id="prob-list"></div>
        <pre class="result-box" id="result-json">Run an experiment.</pre>
      </aside>
    </div>
  </main>
</Layout>

<script>
  function getApiBase() {
    const params = new URLSearchParams(window.location.search);
    const fromParam = params.get('api');
    if (fromParam) {
      localStorage.setItem('ai_lab_api', fromParam);
      return fromParam.replace(/\/$/, '');
    }
    return (localStorage.getItem('ai_lab_api') || 'http://localhost:8000').replace(/\/$/, '');
  }

  const API = getApiBase();

  const toolMeta = {
    text: { title: 'Text AI', runtime: 'go runtime' },
    iris: { title: 'Iris classifier', runtime: 'python / sklearn' },
    digits: { title: 'Digit recognizer', runtime: 'python / sklearn' },
    external: { title: 'External API', runtime: 'http provider' },
  };

  const resultLabel = document.getElementById('result-label');
  const resultMeta = document.getElementById('result-meta');
  const resultEngine = document.getElementById('result-engine');
  const resultJson = document.getElementById('result-json');
  const probList = document.getElementById('prob-list');
  const toolTitle = document.getElementById('tool-title');
  const toolRuntime = document.getElementById('tool-runtime');

  function setTool(tool) {
    document.querySelectorAll('[data-tool]').forEach((button) => {
      button.classList.toggle('active', button.getAttribute('data-tool') === tool);
    });
    document.querySelectorAll('[data-screen]').forEach((screen) => {
      screen.classList.toggle('active', screen.getAttribute('data-screen') === tool);
    });

    const meta = toolMeta[tool] || toolMeta.text;
    if (toolTitle) toolTitle.textContent = meta.title;
    if (toolRuntime) toolRuntime.textContent = meta.runtime;
  }

  function setBusy(button, busy) {
    if (!button) return;
    if (busy) button.setAttribute('disabled', 'true');
    else button.removeAttribute('disabled');
  }

  function setOutput(label, engine, data, probabilities = []) {
    if (resultLabel) resultLabel.textContent = label;
    if (resultEngine) resultEngine.textContent = engine;
    if (resultMeta) resultMeta.textContent = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    if (resultJson) resultJson.textContent = typeof data === 'string' ? data : JSON.stringify(data, null, 2);
    renderProbabilities(probabilities);
  }

  function renderProbabilities(probabilities) {
    if (!probList) return;
    probList.innerHTML = '';
    if (!Array.isArray(probabilities) || probabilities.length === 0) return;

    probabilities
      .slice()
      .sort((a, b) => b.probability - a.probability)
      .forEach((item) => {
        const row = document.createElement('div');
        row.className = 'prob-row';

        const label = document.createElement('span');
        label.textContent = item.label;

        const meter = document.createElement('div');
        meter.className = 'meter';
        const fill = document.createElement('span');
        fill.style.width = `${Math.max(0, Math.min(100, item.probability * 100))}%`;
        meter.appendChild(fill);

        const value = document.createElement('span');
        value.className = 'mono';
        value.textContent = `${(item.probability * 100).toFixed(1)}%`;

        row.append(label, meter, value);
        probList.appendChild(row);
      });
  }

  async function postJson(path, payload) {
    const response = await fetch(`${API}${path}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const data = await response.json();
    if (!response.ok) throw new Error(data.detail || 'Request failed');
    return data;
  }

  async function refreshEngines() {
    const target = document.getElementById('runtime-chips');
    if (!target) return;

    try {
      const response = await fetch(`${API}/api/lab/engines`);
      if (!response.ok) throw new Error('offline');
      const data = await response.json();
      target.innerHTML = '';
      data.engines.forEach((engine) => {
        const chip = document.createElement('span');
        chip.className = `chip ${engine.status === 'ready' ? 'green' : engine.status === 'unconfigured' || engine.status === 'unavailable' || engine.status === 'fallback' ? 'amber' : ''}`;
        chip.textContent = `${engine.runtime}: ${engine.status}`;
        target.appendChild(chip);
      });
    } catch {
      target.innerHTML = '<span class="chip amber">backend offline</span>';
    }
  }

  document.querySelectorAll('[data-tool]').forEach((button) => {
    button.addEventListener('click', () => {
      setTool(button.getAttribute('data-tool') || 'text');
    });
  });

  document.querySelectorAll('[data-iris]').forEach((input) => {
    const id = input.getAttribute('data-iris');
    const value = document.getElementById(`iris-${id}-value`);
    input.addEventListener('input', () => {
      if (value) value.textContent = input.value;
    });
  });

  document.getElementById('text-run')?.addEventListener('click', async (event) => {
    const button = event.currentTarget;
    const text = document.getElementById('text-input')?.value?.trim();
    if (!text) return;

    setBusy(button, true);
    setOutput('Running', 'go_text_ai', 'running...');
    try {
      const data = await postJson('/api/lab/text/analyze', { text });
      setOutput(data.label, data.engine, data);
    } catch (error) {
      setOutput('Error', 'go_text_ai', error instanceof Error ? error.message : 'Request failed');
    } finally {
      setBusy(button, false);
    }
  });

  document.getElementById('iris-run')?.addEventListener('click', async (event) => {
    const button = event.currentTarget;
    const features = Array.from(document.querySelectorAll('[data-iris]')).map((input) => Number(input.value));

    setBusy(button, true);
    setOutput('Running', 'iris_classifier', 'running...');
    try {
      const data = await postJson('/api/models/iris_classifier/predict', { features });
      setOutput(data.prediction, data.model_id, data, data.probabilities);
    } catch (error) {
      setOutput('Error', 'iris_classifier', error instanceof Error ? error.message : 'Request failed');
    } finally {
      setBusy(button, false);
    }
  });

  const digitGrid = document.getElementById('digit-grid');
  const digitValues = Array(64).fill(0);
  const digitCells = [];
  let isPainting = false;

  function paintDigit(index, value = 16) {
    digitValues[index] = value;
    const cell = digitCells[index];
    if (!cell) return;
    const level = value / 16;
    cell.style.background = value > 0 ? `rgba(244, 244, 245, ${0.25 + level * 0.75})` : '#050505';
    cell.setAttribute('aria-pressed', value > 0 ? 'true' : 'false');
  }

  if (digitGrid) {
    for (let index = 0; index < 64; index += 1) {
      const cell = document.createElement('button');
      cell.type = 'button';
      cell.className = 'digit-cell';
      cell.setAttribute('aria-label', `pixel ${index + 1}`);
      cell.setAttribute('aria-pressed', 'false');
      cell.addEventListener('pointerdown', (event) => {
        isPainting = true;
        paintDigit(index, event.shiftKey ? 0 : 16);
      });
      cell.addEventListener('pointerenter', () => {
        if (isPainting) paintDigit(index, 16);
      });
      digitCells.push(cell);
      digitGrid.appendChild(cell);
    }
  }

  document.addEventListener('pointerup', () => {
    isPainting = false;
  });

  document.getElementById('digit-clear')?.addEventListener('click', () => {
    digitValues.forEach((_, index) => paintDigit(index, 0));
    setOutput('Cleared', 'digits_classifier', 'Draw a digit.');
  });

  document.getElementById('digit-run')?.addEventListener('click', async (event) => {
    const button = event.currentTarget;
    setBusy(button, true);
    setOutput('Running', 'digits_classifier', 'running...');
    try {
      const data = await postJson('/api/models/digits_classifier/predict', { features: digitValues });
      setOutput(data.prediction, data.model_id, data, data.probabilities);
    } catch (error) {
      setOutput('Error', 'digits_classifier', error instanceof Error ? error.message : 'Request failed');
    } finally {
      setBusy(button, false);
    }
  });

  document.getElementById('external-run')?.addEventListener('click', async (event) => {
    const button = event.currentTarget;
    const message = document.getElementById('external-message')?.value?.trim();
    const model = document.getElementById('external-model')?.value?.trim();
    if (!message) return;

    setBusy(button, true);
    setOutput('Running', 'external_ai', 'running...');
    try {
      const data = await postJson('/api/lab/external/chat', { message, model: model || undefined });
      setOutput(data.model, data.engine, data.content || data);
    } catch (error) {
      setOutput('Error', 'external_ai', error instanceof Error ? error.message : 'Request failed');
    } finally {
      setBusy(button, false);
    }
  });

  const params = new URLSearchParams(window.location.search);
  const model = params.get('model');
  if (model === 'iris_classifier') setTool('iris');
  else if (model === 'digits_classifier') setTool('digits');
  else if (window.location.hash === '#external') setTool('external');
  else setTool('text');

  refreshEngines();
</script>

<style>
  .lab-page {
    padding-bottom: 18px;
  }

  .lab-shell {
    display: grid;
    grid-template-columns: 170px minmax(0, 1fr) minmax(320px, 0.72fr);
    gap: 14px;
    min-height: calc(100vh - var(--nav-height) - 56px);
  }

  .tool-rail {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 10px;
  }

  .tool-tab {
    justify-content: flex-start;
    width: 100%;
    padding: 0 12px;
    cursor: pointer;
    background: transparent;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 750;
  }

  .tool-tab:hover,
  .tool-tab.active {
    border-color: var(--border);
    background: var(--surface-2);
    color: var(--text);
  }

  .tool-tab.active svg {
    color: var(--accent);
  }

  .work-panel,
  .output-panel {
    display: flex;
    flex-direction: column;
    min-width: 0;
    padding: 18px;
  }

  .work-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 18px;
  }

  .runtime-chips,
  .result-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 6px;
  }

  .tool-screen {
    display: none;
    flex: 1;
  }

  .tool-screen.active {
    display: grid;
    align-content: start;
    gap: 16px;
  }

  .slider-list {
    display: grid;
    gap: 18px;
  }

  .field-row {
    display: grid;
    gap: 8px;
  }

  .field-row label {
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }

  .field-row span {
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .action-row {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
  }

  .action-row.split {
    justify-content: space-between;
  }

  .digit-wrap {
    display: grid;
    justify-content: start;
  }

  .digit-grid {
    display: grid;
    grid-template-columns: repeat(8, 32px);
    grid-template-rows: repeat(8, 32px);
    gap: 5px;
    touch-action: none;
  }

  .digit-cell {
    width: 32px;
    height: 32px;
    cursor: crosshair;
    border: 1px solid var(--border);
    border-radius: 5px;
    background: #050505;
  }

  .digit-cell:hover {
    border-color: var(--accent);
  }

  .output-panel {
    gap: 14px;
  }

  .output-head {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .output-panel .result-box {
    flex: 1;
    min-height: 240px;
  }

  .prob-list {
    display: grid;
    gap: 8px;
  }

  @media (max-width: 1060px) {
    .lab-shell {
      grid-template-columns: 1fr;
    }

    .tool-rail {
      flex-direction: row;
      overflow-x: auto;
    }

    .tool-tab {
      width: auto;
      min-width: 112px;
    }
  }

  @media (max-width: 520px) {
    .work-top,
    .result-meta {
      align-items: flex-start;
      flex-direction: column;
    }

    .runtime-chips {
      justify-content: flex-start;
    }

    .digit-grid {
      grid-template-columns: repeat(8, minmax(24px, 1fr));
      grid-template-rows: repeat(8, 1fr);
      width: min(100%, 296px);
      aspect-ratio: 1;
    }

    .digit-cell {
      width: 100%;
      height: auto;
      aspect-ratio: 1;
    }
  }
</style>
